generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id     String @id @default(cuid())
  email  String @unique
  plan   String @default("free")
  isPaid Boolean @default(false)

  leads  Lead[]
}

model Lead {
  id      String @id @default(cuid())
  phone   String
  events  String

  userId  String
  user    User   @relation(fields: [userId], references: [id])
}